{
  "manifest_version": 3,
  "name": "Cleanor Image Optimizer: Compress & Convert",
  "version": "0.8.1",
  "description": "Compress and convert images (incl. HEIC & AVIF) right in your browser. Private by design: your files never leave the device.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cleanor Image Optimizer",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "contextMenus",
    "downloads",
    "storage",
    "scripting",
    "activeTab",
    "clipboardWrite"
  ],
  "commands": {
    "open-optimizer": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "Alt+Shift+C"
      },
      "description": "Open the Cleanor image optimizer"
    }
  },
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "homepage_url": "https://cleanor.app/tools"
}